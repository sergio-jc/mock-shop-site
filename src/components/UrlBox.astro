---
interface Props {
  label: string;
  url: string;
}
const { label, url } = Astro.props;
---

<div class="url-box">
  <span class="url-label">{label}</span>
  <span class="url-value">{url}</span>

  <!-- Copy button -->
  <button class="copy-btn" data-url={url} aria-label="Copy URL" title="Copy URL">
    <svg class="icon-copy icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg class="icon-check icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </button>
</div>

<style scoped>
  .url-box {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    /* border: 1px solid var(--sl-color-accent); */
    background: var(--sl-color-bg-nav);
    padding: 0.75rem 3rem 0.75rem 1.25rem;
    border-radius: 0.375rem;
    font-family: var(--sl-font-mono, monospace);
    margin: 0.5rem 0.5;
  }

  .url-label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-text-accent);
    white-space: nowrap;
    flex-shrink: 0;
    font-family: monospace;
    opacity: 0.5;
  }

  .url-value {
    color: var(--sl-color-accent-high);
    font-size: 0.875rem;
    word-break: break-all;
  }

  .copy-btn {
    position: absolute;
    right: 0.625rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.25rem;
    background: transparent;
    color: var(--sl-color-text-accent);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    padding: 0;
  }

  .copy-btn:hover {
    background: var(--sl-color-accent);
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
  }

  .copy-btn.copied {
    color: var(--sl-color-green);
    border-color: var(--sl-color-green);
  }

  .icon {
    margin: 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url ?? '';
      await navigator.clipboard.writeText(url);

      const iconCopy = btn.querySelector<SVGElement>('.icon-copy');
      const iconCheck = btn.querySelector<SVGElement>('.icon-check');

      btn.classList.add('copied');
      if (iconCopy) iconCopy.style.display = 'none';
      if (iconCheck) iconCheck.style.display = '';

      setTimeout(() => {
        btn.classList.remove('copied');
        if (iconCopy) iconCopy.style.display = '';
        if (iconCheck) iconCheck.style.display = 'none';
      }, 2000);
    });
  });
</script>
